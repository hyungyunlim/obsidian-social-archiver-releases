# Obsidian vault path for development
OBSIDIAN_VAULT_PATH=/Users/yourusername/Documents/ObsidianVault

# API Configuration (for development/testing)
API_ENDPOINT=https://api.social-archiver.com
API_KEY=your_api_key_here

# License key for Pro features
LICENSE_KEY=your_license_key_here

# Development settings
DEBUG=true
NODE_ENV=development

# Kakao Local place search is a Worker-only secret. Never put its value in this
# root/client environment file; configure it from `workers/` with:
# npx wrangler secret put KAKAO_REST_API_KEY
# npx wrangler secret put GOOGLE_PLACES_API_KEY
